rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "v.bookenterprise@gmail.com";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Users collection ─────────────────────────────────────
    match /users/{userId} {
      // Only the owner or admin can read/write the profile doc
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      // ── Entries subcollection ──────────────────────────────
      match /entries/{entryId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(["type","amount","category","date"])
                      && request.resource.data.amount is number
                      && request.resource.data.amount >= 0
                      && request.resource.data.type in ["income","expense"]
                      && request.resource.data.date is string;
        allow update: if isOwner(userId)
                      && request.resource.data.amount is number
                      && request.resource.data.amount >= 0;
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ── Settings subcollection ────────────────────────────
      match /settings/{settingId} {
        allow read: if isOwner(userId) || isAdmin();

        // prefs (branding, currency, categories) — owner can write freely
        allow write: if isOwner(userId) && settingId == "prefs";

        // plan — owner can only READ their plan, not write it
        // (plan is written exclusively by server-side functions via firebase-admin)
        allow read:  if isOwner(userId) || isAdmin();
        allow write: if isAdmin(); // Only admin SDK (server) can upgrade/downgrade
      }

      // ── Budgets subcollection ─────────────────────────────
      match /budgets/{budgetId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(["name","startDate","endDate"])
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0;
        allow update: if isOwner(userId)
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0;
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ── Notifications subcollection ───────────────────────
      match /notifications/{notifId} {
        allow read:   if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(["title","body","type","read"])
                      && request.resource.data.title is string
                      && request.resource.data.read is bool;
        allow update: if isOwner(userId); // for marking as read
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // ── Deny everything else ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
