# ─────────────────────────────────────────────────────────────
# Cash Counter — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# All secret keys must be saved as Sensitive type in Vercel.
# ─────────────────────────────────────────────────────────────

# ── Firebase (Client SDK — VITE_ prefix required) ────────────
# Get from: Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin SDK (Server-side only — no VITE_ prefix) ──
# Get from: Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Paystack ─────────────────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
# Use live keys for production, test keys (pk_test_ / sk_test_) for staging
VITE_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Paystack plan codes — only set these on staging (test plan codes)
# Production falls back to hardcoded live plan codes in App.jsx
# VITE_PAYSTACK_PLAN_MONTHLY=PLN_gh2mcit6fixix9k
# VITE_PAYSTACK_PLAN_BIANNUALLY=PLN_gxtrrhn8z2tfqmf
# VITE_PAYSTACK_PLAN_ANNUALLY=PLN_87ghrcbnb4p8aaa

# ── Mono ─────────────────────────────────────────────────────
# Get from: app.mono.co → your app → API Keys
# Use test keys for staging, live keys for production
VITE_MONO_PUBLIC_KEY=
MONO_SECRET_KEY=

# ── Upstash Redis (Rate limiting) ────────────────────────────
# Get from: console.upstash.com → your database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend (Email) ───────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=

# ── App URL ──────────────────────────────────────────────────
# Used for Paystack callback URLs. Set to your deployment URL.
# Production: https://cashcounter.vbookng.com
# Staging: https://ledgerbook-staging-akinnusiadebayo-4892s-projects.vercel.app
APP_URL=https://cashcounter.vbookng.com

# ── Admin ────────────────────────────────────────────────────
# Secret key for admin-only API operations
ADMIN_SECRET=

# ── Environment flag ─────────────────────────────────────────
# Set to "staging" on the staging Vercel project only
# VITE_ENV=staging

# ── Ninja Firebase (Separate project — vbook-ninja) ──────────
# Get from: Firebase Console → vbook-ninja project → Service Accounts
NINJA_FIREBASE_PROJECT_ID=
NINJA_FIREBASE_CLIENT_EMAIL=
NINJA_FIREBASE_PRIVATE_KEY=
